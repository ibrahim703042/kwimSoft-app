{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@kwim/shared-ui": ["../../shared-ui/src/index.ts"],
      "@kwim/core": ["../../core/src/index.ts"],
      "@kwim/auth": ["../../auth/src/index.ts"]
    }
  },
  "include": ["src"]
}
