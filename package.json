{
  "name": "@kwim/monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @kwim/admin dev",
    "dev:web": "pnpm --filter @kwim/web dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:admin": "pnpm --filter @kwim/admin build",
    "build:web": "pnpm --filter @kwim/web build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "eslint": "^9.13.0"
  }
}
