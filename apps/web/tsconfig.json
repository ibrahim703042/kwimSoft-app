{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": "./src",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"],
      "@/app/*": ["app/*"],
      "@/core/*": ["core/*"],
      "@/modules/*": ["modules/*"],
      "@/components/*": ["components/*"],
      "@/hooks/*": ["hooks/*"],
      "@/lib/*": ["lib/*"],
      "@/assets/*": ["assets/*"],
      "@/store/*": ["store/*"],
      "@/styles/*": ["styles/*"],
      "@/config": ["config/index.ts"]
    }
  }
}
